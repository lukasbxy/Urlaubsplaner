# Kopiere nach .env und fülle echte Werte ein ( .env wird nicht ins Repo committet ).

# Optional: Gemini / KI (falls genutzt)
VITE_GEMINI_API_KEY=

# Öffentliche App-URL (OAuth, Links)
APP_URL=

# Google Maps (Karte / Routen)
VITE_GOOGLE_MAPS_API_KEY=

# Supabase (Pflicht für die App)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Nur für GitHub-Pages-Build in Actions (lokal meist leer lassen)
# Projekt-Site: /REPO_NAME/ mit trailing slash, z. B. /Urlaubsplaner/
VITE_BASE_PATH=/

# Seed-Skript scripts/seed-supabase.cjs (niemals Service-Role committen)
# SUPABASE_SERVICE_ROLE_KEY=
