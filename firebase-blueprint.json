{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A planned vacation or trip",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "collaboratorIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "flightCost": { "type": "number" }
      },
      "required": ["title", "ownerId", "collaboratorIds", "createdAt"]
    },
    "TripItem": {
      "title": "Trip Item",
      "description": "An event, location, or booking within a trip",
      "type": "object",
      "properties": {
        "tripId": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["location", "flight", "accommodation", "activity", "transport", "train"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "isAllDay": { "type": "boolean" },
        "locationName": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "endLocationName": { "type": "string" },
        "endLat": { "type": "number" },
        "endLng": { "type": "number" },
        "cost": { "type": "number" },
        "bookingReference": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tripId", "type", "title", "order", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "trips/{tripId}": {
      "schema": { "$ref": "#/entities/Trip" },
      "description": "Trips created by users"
    },
    "trips/{tripId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/TripItem" },
      "description": "Items belonging to a trip"
    }
  }
}
